rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user authenticated?
    function signedIn() {
      return request.auth != null;
    }

    // Helper: Is the user a member of the group?
    function isGroupMember(groupId, email) {
      return exists(/databases/$(database)/documents/members/$(groupId + "_" + email));
    }

    // Helper: Get the group document data
    function getGroup(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId));
    }

    // Helper: Is the user the leader of the group?
    function isGroupLeader(groupId, uid) {
      return getGroup(groupId).data.leaderId == uid;
    }

    // Groups collection rules
    match /groups/{groupId} {
      // Anyone who is a member of the group can read it
      allow read: if signedIn() && isGroupMember(groupId, request.auth.token.email);
      
      // Any authenticated user can create a group if they set themselves as leader
      allow create: if signedIn() && request.resource.data.leaderId == request.auth.uid;
      
      // Only the leader can edit or delete the group itself
      allow update, delete: if signedIn() && resource.data.leaderId == request.auth.uid;
    }

    // Members collection rules
    match /members/{memberId} {
      // A user can read a member doc if they are either that member or in the same group
      allow read: if signedIn() && (
        resource.data.email == request.auth.token.email || 
        isGroupMember(resource.data.groupId, request.auth.token.email)
      );
      
      // Creating a member doc:
      // 1. A user can create their own 'leader' doc when initializing a group.
      // 2. The group leader can add other email addresses as standard 'member's.
      allow create: if signedIn() && (
        (request.resource.data.role == 'leader' && request.resource.data.userId == request.auth.uid && request.resource.data.email == request.auth.token.email) ||
        (request.resource.data.role == 'member' && isGroupLeader(request.resource.data.groupId, request.auth.uid))
      );
                    
      // Only the group leader can remove members (leaders cannot be removed)
      allow delete: if signedIn() && 
                    resource.data.role != 'leader' && 
                    isGroupLeader(resource.data.groupId, request.auth.uid);
    }

    // Expenses collection rules
    match /expenses/{expenseId} {
      // Everyone in the group can view the expenses
      allow read: if signedIn() && isGroupMember(resource.data.groupId, request.auth.token.email);
      
      // Group members can add expenses
      allow create: if signedIn() && 
                    isGroupMember(request.resource.data.groupId, request.auth.token.email) && 
                    request.resource.data.createdBy == request.auth.uid;
                    
      // Users can edit or delete only their own expenses
      allow update, delete: if signedIn() && 
                            resource.data.createdBy == request.auth.uid;
    }
  }
}
